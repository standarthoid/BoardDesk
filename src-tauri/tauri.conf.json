{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BoardDesk",
  "version": "0.1.0",
  "identifier": "com.boarddesk.desktop",
  "app": {
    "windows": [
      {
        "title": "BoardDesk",
