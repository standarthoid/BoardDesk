{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BoardDesk",
  "version": "0.1.0",
  "identifier": "com.boarddesk.app",
  "app": {
    "windows": [
      {
        "title": "BoardDesk",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: https://cdnjs.cloudflare.com; media-src 'self' data: blob: *; img-src 'self' data: blob: *; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdnjs.cloudflare.com; worker-src blob: 'self';"
    }
  },
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "python3 -m http.server 1420 --directory /Users/miriamhanke/Downloads/BoardDesk",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "signingIdentity": null
    }
  }
}
